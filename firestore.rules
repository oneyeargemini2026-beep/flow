rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: tasks
    // Fields:
    //   - userId: string (required) - Owner's UID
    //   - title: string (required) - Task title
    //   - completed: bool (required) - Completion status
    //
    // Collection: folders
    // Fields:
    //   - userId: string (required) - Owner's UID
    //   - name: string (required) - Folder name
    //
    // Collection: tags
    // Fields:
    //   - userId: string (required) - Owner's UID
    //   - name: string (required) - Tag name
    //
    // Collection: matrixConfigs
    // Fields:
    //   - userId: string (required) - Owner's UID
    //   - q1, q2, q3, q4: map (required) - Quadrant configs
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && (
        (resource == null && 'userId' in request.resource.data && request.auth.uid == request.resource.data.userId) ||
        (resource != null && (!('userId' in resource.data) || request.auth.uid == resource.data.userId))
      );
    }

    function uidUnchanged() {
      return !('userId' in request.resource.data) ||
        request.resource.data.userId == request.auth.uid;
    }

    function uidNotModified() {
      return resource == null || request.resource.data.userId == resource.data.userId;
    }

    // Generic validator for documents with userId
    function isValidDocument(data) {
      return data.userId is string && data.userId.size() > 0;
    }

    // Tasks Collection
    match /tasks/{taskId} {
      allow read: if isDocOwner();
      allow create: if isDocOwner() && isValidDocument(request.resource.data);
      allow update: if isDocOwner() && isValidDocument(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    // Folders Collection
    match /folders/{folderId} {
      allow read: if isDocOwner();
      allow create: if isDocOwner() && isValidDocument(request.resource.data);
      allow update: if isDocOwner() && isValidDocument(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    // Tags Collection
    match /tags/{tagId} {
      allow read: if isDocOwner();
      allow create: if isDocOwner() && isValidDocument(request.resource.data);
      allow update: if isDocOwner() && isValidDocument(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    // Goals Collection
    match /goals/{goalId} {
      allow read: if isDocOwner();
      allow create: if isDocOwner() && isValidDocument(request.resource.data);
      allow update: if isDocOwner() && isValidDocument(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    // Archives Collection
    match /archives/{archiveId} {
      allow read: if isDocOwner();
      allow create: if isDocOwner() && isValidDocument(request.resource.data);
      allow update: if isDocOwner() && isValidDocument(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    // Notes Collection
    match /notes/{noteId} {
      allow read: if isDocOwner();
      allow create: if isDocOwner() && isValidDocument(request.resource.data);
      allow update: if isDocOwner() && isValidDocument(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    // MatrixConfigs Collection
    match /matrixConfigs/{configId} {
      allow read: if isAuthenticated() && (request.auth.uid == configId || (resource != null && request.auth.uid == resource.data.userId));
      allow create: if isAuthenticated() && isValidDocument(request.resource.data) && request.auth.uid == configId && request.auth.uid == request.resource.data.userId;
      allow update: if isAuthenticated() && isValidDocument(request.resource.data) && request.auth.uid == configId && request.auth.uid == resource.data.userId && request.resource.data.userId == resource.data.userId;
      allow delete: if isAuthenticated() && request.auth.uid == configId && request.auth.uid == resource.data.userId;
    }
  }
}
