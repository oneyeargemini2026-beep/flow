{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "A user's profile information.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "photoURL": { "type": "string", "description": "The user's photo URL." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the user account was last updated." }
      },
      "required": ["email", "createdAt"]
    },
    "Task": {
      "title": "Task",
      "description": "A task item.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the task." },
        "description": { "type": "string", "description": "Detailed description of the task." },
        "status": { 
          "type": "string", 
          "enum": ["inbox", "todo", "in-progress", "done", "archived"],
          "description": "The current status of the task." 
        },
        "priority": {
          "type": "string",
          "enum": ["p1", "p2", "p3", "p4"],
          "description": "Priority level."
        },
        "dueDate": { "type": "string", "format": "date-time", "description": "Due date for the task." },
        "dueTime": { "type": "string", "description": "Due time for the task." },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "List of tags." },
        "project": { "type": "string", "description": "Project name." },
        "section": { "type": "string", "description": "Section name." },
        "isInbox": { "type": "boolean", "description": "Is in inbox." },
        "deleted": { "type": "boolean", "description": "Is deleted." },
        "completed": { "type": "boolean", "description": "Is completed." },
        "completedDate": { "type": "string", "format": "date-time", "description": "Completion date." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp." }
      },
      "required": ["title", "createdAt", "updatedAt"]
    },
    "Folder": {
      "title": "Folder",
      "description": "A folder containing projects.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Folder name." },
        "color": { "type": "string", "description": "Folder color." },
        "open": { "type": "boolean", "description": "Is folder open." },
        "projects": { "type": "array", "items": { "type": "string" }, "description": "List of project names." },
        "deleted": { "type": "boolean", "description": "Is deleted." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["name", "color", "createdAt"]
    },
    "Archive": {
      "title": "Archive",
      "description": "An archive record.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Archive name." },
        "color": { "type": "string", "description": "Archive color." },
        "start": { "type": "string", "format": "date-time", "description": "Start date." },
        "end": { "type": "string", "format": "date-time", "description": "End date." },
        "tasks": { "type": "number", "description": "Total tasks." },
        "completed": { "type": "number", "description": "Completed tasks." },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Tags." },
        "quarter": { "type": "string", "enum": ["q1", "q2", "q3", "q4"], "description": "Quarter." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["name", "createdAt"]
    },
    "MatrixConfig": {
      "title": "Matrix Config",
      "description": "Configuration for the Eisenhower Matrix.",
      "type": "object",
      "properties": {
        "q1": { "$ref": "MatrixQuadrant" },
        "q2": { "$ref": "MatrixQuadrant" },
        "q3": { "$ref": "MatrixQuadrant" },
        "q4": { "$ref": "MatrixQuadrant" }
      },
      "required": ["q1", "q2", "q3", "q4"]
    },
    "MatrixQuadrant": {
      "title": "Matrix Quadrant",
      "description": "Quadrant details.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["title", "subtitle", "color"]
    },
    "Tag": {
      "title": "Tag",
      "description": "A tag for categorizing tasks.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the tag." },
        "color": { "type": "string", "description": "Hex color code for the tag." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["name", "color", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "users/{userId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "Tasks belonging to a user."
    },
    "users/{userId}/folders/{folderId}": {
      "schema": "Folder",
      "description": "Folders belonging to a user."
    },
    "users/{userId}/archives/{archiveId}": {
      "schema": "Archive",
      "description": "Archives belonging to a user."
    },
    "users/{userId}/tags/{tagId}": {
      "schema": "Tag",
      "description": "Tags created by a user."
    },
    "users/{userId}/settings/matrix": {
      "schema": "MatrixConfig",
      "description": "User's matrix configuration."
    }
  }
}
